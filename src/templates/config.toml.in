# {{user_config_dir}}/config.toml
# Denia control-plane configuration (TOML; mirrors src/config.rs::FileConfig).
# Read by the daemon at boot. DENIA_* environment variables in the systemd unit
# override per-field (see docs/adr/023). The admin token lives in
# {{token_file}}; keep it out of this file.
# Rendered by cli::common::config_writer::render_config_toml.

# --- Control plane bind ---
# Management API socket. Pingora handles :80/:443; this is only the
# operator-facing /v1 + /healthz + SPA. Keep loopback unless access is
# protected by a private network, tunnel, or future control-plane TLS.
bind_addr = "127.0.0.1:7180"

# --- On-disk layout ---
data_dir = "/var/lib/denia"
database_path = "/var/lib/denia/sqlite/denia.sqlite3"
tls_dir = "/var/lib/denia/tls"
node_disk_path = "/var/lib/denia"

# --- Workload runtime ---
cgroup_root = "/sys/fs/cgroup/denia"
# Subuid/subgid mapping for workloads (see ADR-005). Default 100000 / 65536;
# raise userns_size if you run many workloads.
userns_base = 100000
userns_size = 65536

# --- External tool paths (PATH lookup if commented) ---
# buildkit_binary = "/usr/local/bin/buildctl"
# git_binary = "/usr/bin/git"
# sops_binary = "/usr/local/bin/sops"
# socket_proxy_binary: defaults to the running denia binary (current_exe).
# Set explicitly only if the daemon cannot resolve its own path.
# socket_proxy_binary = "/usr/local/bin/denia"

# --- Ingress (Pingora) ---
# ACME HTTP-01 lives on :80; keep it 80 unless you front it (don't -- Denia
# owns these).
http_port = 80
https_port = 443
# Let's Encrypt production. Use the staging URL on non-prod nodes:
# acme_directory_url = "https://acme-staging-v02.api.letsencrypt.org/directory"
acme_directory_url = "https://acme-v02.api.letsencrypt.org/directory"
# Required if any service has tls_enabled = true:
# acme_email = "ops@example.com"

# --- ACME challenge (ADR-038) ---
# "http-01" (default) needs Let's Encrypt to reach :80 directly. Use "dns-01" to
# issue via a DNS provider instead -- this works when the domain is fronted by a
# proxy (Cloudflare orange-cloud, a WAF), where HTTP-01 cannot reach :80.
# acme_challenge = "dns-01"
#
# DNS-01 provider: "cloudflare" (default) or "exec".
# acme_dns_provider = "cloudflare"
#
# cloudflare: API token with Zone:Read + DNS:Edit. SECRET: never put the token
# value in this file. Set DENIA_CF_DNS_API_TOKEN in the systemd unit, or point
# cf_dns_api_token_file at a 0600 file holding `DENIA_CF_DNS_API_TOKEN=<token>`.
# cf_dns_api_token_file = "{{user_config_dir}}/cf-dns.token"
#
# exec: a script Denia runs as `<script> present|cleanup <fqdn> <value>` to
# manage the TXT record on ANY DNS host (Akamai, Route53, PowerDNS, BIND, ...).
# Denia holds no credential -- the script owns its own auth.
# acme_dns_exec = "/usr/local/bin/denia-dns-hook"
#
# Seconds to wait before checking propagation (default 60):
# acme_dns_propagation_secs = 60
# DoH endpoints polled to confirm propagation (also used to resolve CNAME
# delegation). Default (when unset): built-in public resolvers (Cloudflare +
# Google). Override to pin your own:
# acme_dns_resolvers = ["https://cloudflare-dns.com/dns-query"]

# --- Control-plane TLS gating ---
# control_domain = "denia.example.com"
# control_tls = false

# --- Autoscaler ---
autoscale_interval_s = 15
autoscale_headroom_cpu_millis = 1000
autoscale_headroom_mem_bytes = 536870912

# --- Control-plane secret encryption (ADR-021) ---
# Age private key file. The public recipient is auto-derived from the
# "# public key:" comment unless age_recipient is set explicitly.
age_key_file = "{{age_key_file}}"
# age_recipient = "age1..."

# --- OCI layer cache (ADR-022; all optional, shown with defaults) ---
# oci_cache_dir = "/var/lib/denia/oci-cache"
# Cache-hit verification: "none" | "size" | "full".
# oci_cache_verify_on_hit = "size"
# Blob GC scan interval / retention, in seconds (default 7 days each).
# oci_gc_interval_secs = 604800
# oci_gc_retention_secs = 604800

# --- Hosted registry GC (ADR-031; env-only knobs, shown for reference) ---
# DENIA_REGISTRY_GC_INTERVAL_SECS (default 86400)
# DENIA_REGISTRY_GC_GRACE_SECS    (default 3600)

# --- Push upload staging (ADR-034; all optional, shown with defaults) ---
# uploads_dir = "/var/lib/denia/uploads"
# upload_max_bytes = 536870912            # 512 MiB on-the-wire
# upload_max_uncompressed_bytes = 2147483648  # 2 GiB extracted
# upload_max_entries = 200000
# upload_ttl_secs = 3600
